{%- if template == 'index' -%}
<!-- Homepage non-critical CSS: deferred until interaction or browser idle -->
<script>
  (function() {
    var coreLoaded = false;
    var bootstrapLoaded = false;
    function appendStyleOnce(id, href) {
      if (document.getElementById(id)) return;
      var link = document.createElement('link');
      link.id = id;
      link.rel = 'stylesheet';
      link.href = href;
      document.head.appendChild(link);
    }
    function loadCoreHomepageCSS() {
      if (coreLoaded) return;
      coreLoaded = true;
      appendStyleOnce('theme-scss-css', "{{ 'theme.scss.css' | asset_url }}");
      appendStyleOnce('custom-css', "{{ 'custom.css' | asset_url }}");
    }
    function loadBootstrapCSS() {
      if (bootstrapLoaded) return;
      bootstrapLoaded = true;
      appendStyleOnce('bootstrap-css', "{{ 'bootstrap.min.css' | asset_url }}");
    }
    function loadAllHomepageCSS() {
      loadCoreHomepageCSS();
      loadBootstrapCSS();
    }
    ['scroll', 'mousemove', 'touchstart', 'keydown'].forEach(function(evt) {
      window.addEventListener(evt, loadAllHomepageCSS, { once: true, passive: true });
    });
    window.addEventListener('load', function() {
      // Keep non-critical homepage styles out of the initial render path.
      setTimeout(loadCoreHomepageCSS, 7000);
      setTimeout(loadBootstrapCSS, 12000);
    }, { once: true });
  })();
</script>
