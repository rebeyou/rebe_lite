{%- if settings.enable_breadcrumb -%}
{% unless template == 'index' or template == 'cart' or template == 'list-collections' %}
<style>
  .g-breadcrumb{
    border-radius: 0;
    flex-direction: column;
    color:{{settings.color_breadcrumbs}} ;
    padding:20px 0;
    margin:0;
    background:{{settings.bg_breadcrumb}};}
  .g-breadcrumb a,.g-breadcrumb span{padding:0 3px;font-size:14px;line-height:20px;display:inline-block;}
  .g-breadcrumb a{
    color:{{settings.color_breadcrumbs_active}};
  }
  .g-breadcrumb .container,.g-breadcrumb .container-fluid{z-index: 2;position: relative;}
  .g-breadcrumb.breadcrumbs-style_2{
    padding:80px 0;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    border-radius: 0;
  }
  @media (max-width:576px) {
    .g-breadcrumb.breadcrumbs-style_2{
      padding: 50px 0;
    }
    .g-breadcrumb.breadcrumbs-style_2 h3{
      font-size: 26px;
    }
  }
  .g-breadcrumb.breadcrumbs-style_2::before{
    background:rgba(0,0,0,{{settings.limit_ranger}});
    position: absolute;
    z-index: 1;
    content:"";
    left: 0;
    right: 0;
    bottom:0;
    top: 0;
  }
  .br-title{
    color:{{settings.color_breadcrumbs}}
  }
  .br-title svg{
    width: 23px;
    height: 23px;
  }
</style>
{% assign bgimage = settings.img_breadcrumb %}
{% if template contains 'collection' and collection.handle %}
  {% assign bgimage = collection.image.src %}
  {% if collection.image.src == blank %}
    {% assign bgimage = settings.img_breadcrumb %}
  {% endif %}
{% elsif template contains 'product' and collection.handle %}    
  {% assign bgimage = collection.image.src %}
{% endif %}

{%- comment -%} Test: Contact page specific image {%- endcomment -%}
 {% if template contains 'page' and page.handle == 'contact' %}
  {% assign bgimage = 'https://cdn.shopify.com/s/files/1/0522/8678/3654/files/Mole_Excision_Lady.webp' %}
{% endif %}

<nav class="breadcrumbs-{{settings.style_breadcrumb}} breadcrumb g-breadcrumb text-{{settings.align_bread}}" role="navigation" aria-label="breadcrumbs" {% unless settings.style_breadcrumb == "style_1" %}data-parent-fit="cover"{% endunless %}>
  
  
  
  {% unless settings.style_breadcrumb == "style_1" %}
  {% if bgimage %}
    {% if bgimage contains 'cdn.shopify.com' or bgimage contains 'asset_url' %}
      <img 
        src="{{ bgimage }}" 
        alt="" 
        fetchpriority="high" 
        loading="eager" 
        class="breadcrumb-bg">
    {% else %}
      <img 
        src="{{ bgimage | image_url: width: 1600 }}" 
        srcset="{{ bgimage | image_url: width: 800 }} 800w,
                {{ bgimage | image_url: width: 1600 }} 1600w"
        sizes="100vw"
        alt="" 
        fetchpriority="high" 
        loading="eager" 
        class="breadcrumb-bg">
    {% endif %}
  {% endif %}
{% endunless %}

  
  
  
  <div class="layer shape-1"></div>
  <div class="{{settings.layout_bread}}">
  {% if settings.show_title_breadcumbs %}
    {% if template contains 'collection' and collection.handle %}
    <h3 class="mb-2 h2 br-title">{{ collection.title }}</h3>
    {% elsif template contains 'page' %}
    <h3 class="mb-2 h2 br-title">{{ page.title }}</h3>
    {% elsif template contains 'product' and collection.handle %}    
      <h3 class="mb-2 h2 br-title">{{ page.title }}</h3>
    {% elsif template contains 'blog' %}    
      <h3 class="mb-2 h2 br-title">{{ blog.title }} {%- include 'icon-rss' -%}</h3>
    {% endif %}
  {% endif %}
  </div>
  <div class="{{settings.layout_bread}}">
    <a href="/" title="Home">Home</a>
    {% if template contains 'page' %}
    <span aria-hidden="true">/</span>
    <span>{{ page.title }}</span>
    {% elsif template contains 'product' %}
    {% if collection.url %}
    <span aria-hidden="true">/</span>
    {{ collection.title | link_to: collection.url }}
    {% endif %}
    <span aria-hidden="true">/</span>
    <span>{{ product.title }}</span>
    {% elsif template contains 'collection' and collection.handle %}
    <span aria-hidden="true">/</span>
    {% if current_tags %}
    {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
    {{ collection.title | link_to: url }}
    <span aria-hidden="true">/</span>
    <span>{{ current_tags | join: " + " }}</span>
    {% else %}
    <span>{{ collection.title }}</span>
    {% endif %}
    {% elsif template == 'blog' %}
    <span aria-hidden="true">/</span>
    {% if current_tags %}
    {{ blog.title | link_to: blog.url }}
    <span aria-hidden="true">/</span>
    <span>{{ current_tags | join: " + " }}</span>
    {% else %}
    <span>{{ blog.title }}</span>
    {% endif %}
    {% elsif template == 'article' %}
    <span aria-hidden="true">/</span>
    {{ blog.title | link_to: blog.url }}
    <span aria-hidden="true">/</span>
    <span>{{ article.title }}</span>
    {% else %}
    <span aria-hidden="true">/</span>
    <span>{{ page_title }}</span>
    {% endif %}
  </div>
  <div class="layer shape-2"></div>
</nav>
{% endunless %}
{%- endif -%}
