              }
            ]
          },
          {
            "type": "select",
            "id": "align",
            "label": "Align",
            "default": "auto",
            "options": [
              {
                "value": "auto",
                "label": "Top"
              },
              {
                "value": "center",
                "label": "Mid"
              },
              {
                "value": "end",
                "label": "Bottom"
              }
            ]
          },
          {
            "type": "video_url",
            "id": "video_url",
            "label": "Video link",
            "accept": [
              "youtube",
              "vimeo"
            ]
          },
          {
            "type": "header",
            "content": "Cover"
          },
          {
            "type": "image_picker",
            "id": "cover_image",
            "label": "Image"
