            "id": "overlay_color",
            "label": "Overlay",
            "default": "#000000"
          },
          {
            "type": "range",
            "id": "overlay_opacity",
            "min": 0,
            "max": 100,
            "step": 5,
            "unit": "%",
            "label": "Opacity",
            "default": 30
          }
