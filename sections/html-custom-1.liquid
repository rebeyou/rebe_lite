              {
                "value": "left",
                "label": "Left"
              },
              {
                "value": "center",
                "label": "Center"
              },
              {
                "value": "right",
                "label": "Right"
              }
            ],
            "default": "center"
          },
          {
            "type": "select",
            "id": "align",
            "label": "Align",
            "default": "auto",
            "options": [
              {
                "value": "auto",
                "label": "Top"
              },
              {
                "value": "center",
                "label": "Mid"
              },
              {
                "value": "end",
