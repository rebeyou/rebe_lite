<!-- sections/grid-banner.liquid -->
{%- render 'grid-banner-bg-style', section: section -%}
<div class="customstyle{{ section.id }} {% if section.settings.bgstyle %}gr-banner-bg{% endif %}" data-aos="{{ section.settings.animation }}">
  {%- if section.settings.bgstyle -%}
    <div class="bg-before" data-aos="{{ section.settings.animation }}" data-aos-duration="500"></div>
  {%- endif -%}
  {%- render 'style-section' -%}
  <div class="{{ section.settings.setwidth }}">
    <div class="section-block">
      {%- render 'section-heading' -%}
      <div class="row {% if section.settings.no_gutter %}no-gutters{% endif %}">
        {%- for block in section.blocks -%}
          {%- render 'grid-banner-block-style', block: block -%}
          <div class="col-md-{{ block.settings.width }}" {{ block.shopify_attributes }} data-aos="{{ section.settings.animation }}" data-aos-duration="1000">
            <figure class="banner-theme hv-image-saturate banner-theme-{{ block.settings.vertical }} banner-theme-{{ block.settings.horizontal }} text-{{ block.settings.text_align }} {% if section.settings.no_gutter %}m-0{% endif %} banner-theme-{{ block.id }} custom-banner-container">
              {%- if block.settings.image != blank -%}
                <img
                  srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1920 }} 1920w"
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  sizes="(max-width: 768px) 100vw, 100vw"
                  class="transition"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  alt="{{ block.settings.image.alt | default: block.settings.aria_label | escape }}">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <figcaption class="figcaption--{{ block.id }} custom-banner-caption">
                {%- if block.settings.description -%}
                  <div class="position-relative">
                    <div class="bg-des"></div>
                    <div class="position-relative" style="z-index: 3;">
                      {{ block.settings.description }}
                    </div>
                  </div>
                {%- endif -%}
                {%- if block.settings.button_text != blank -%}
                  <button class="btn btn-underline btn-underline-white gradient-theme mt-3">
                    {{ block.settings.button_text }}
                    {%- if block.settings.button_icon != blank -%}
                      <span class="d-inline-block ml-2">{{ block.settings.button_icon }}</span>
                    {%- endif -%}
                  </button>
                {%- endif -%}
              </figcaption>
              {%- if block.settings.button_link != blank -%}
                <a href="{{ block.settings.button_link }}" class="stretched-link" aria-label="{{ block.settings.aria_label | default: block.settings.description | strip_html | strip | truncate: 60 | escape }}"></a>
              {%- endif -%}
            </figure>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

