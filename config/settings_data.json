            "type": "html",
            "settings": {
              "code": "<div class=\"row align-items-center layout-column-2\">\n    <div class=\"col-12 col-md-12\">\n        <div class=\"py-5\">\n            <div class=\"py-4 pl-2\">\n                <h3 class=\"h3 bottom-title\">Laser Tattoo Removal</h3>\n                <h3 class=\"text-main line-after\">Tattoo removal treatment</h3>\n                <p class=\"text-blue-main text-italic\">Watch our detailed video on tattoo removal treatment.</p>\n<p>Contact us today to learn more information about our tattoo removal treatment we offer at Rebe.</p>\n<button type=\"submit\" class=\"btn btn-theme\" name=\"commit\"><a href=\"https://www.coolsculpting.com\">\n                        <span class=\"d-none d-sm-block text-white\">Contact Us</span>\n                        <span class=\"d-block d-sm-none\"><i class=\"icon-send\"></i></span>\n                      </a></button>\n            </div>\n        </div>\n    </div>\n</div>",
