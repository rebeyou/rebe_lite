      "advanced-content-page-4-7": {
        "type": "advanced-content-page-4-7",
        "blocks": {
          "fc5d0e33-3274-4be4-841b-d2794de69c46": {
            "type": "image",
            "settings": {
              "width": "50%",
              "align": "auto",
              "image": "shopify://shop_images/close-up-of-cosmetological-lips-enlargment-process-P2JW57K.webp",
