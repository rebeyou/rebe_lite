      "advanced-content-page-4-6": {
        "type": "advanced-content-page-4-6",
        "blocks": {
          "d48d68ef-2436-4c28-814a-907b6c9b72fa": {
            "type": "html",
            "settings": {
              "code": "<div class=\"row align-items-center layout-column-2\">\n    <div class=\"col-12 col-md-12\">\n        <div class=\"py-5\">\n            <div class=\"py-4 pl-2\">\n                <h3 class=\"h3 bottom-title\">Best Quality</h3>\n                <h1 class=\"text-main line-after\">Laser Tattoo<br>Removal</h1>\n                <p class=\"text-blue-main text-italic\">Re*be® offers local anesthesia topically or with injections of Xylocaine.</p>\n<p>These photographs were taken before laser tattoo treatment was started and then after more than a dozen treatments with the laser. Blue pigment and green pigment are the most difficult to remove however we can obtain pretty good results with our Quanta q-switch laser. Your results will be different.</p>\n            </div>\n        </div>\n    </div>\n</div>",
              "width": "50%",
              "align": "auto"
            }
          },
          "7b0d33aa-2b1b-4947-868d-17cf98854259": {
            "type": "html",
            "settings": {
              "code": "<div class=\"elfsight-sapp-50fbc736-9278-47e9-b8b1-79c898f6a0ac\"></div>",
