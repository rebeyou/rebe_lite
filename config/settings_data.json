            "settings": {
              "code": "<div class=\"doctor-profile-layout\">\n  <div class=\"row align-items-center\">\n    <!-- Text Content Column -->\n    <div class=\"col-12 col-md-6 mb-4 mb-md-0\">\n      <div class=\"personal-info\">\n        <div class=\"wpb_wrapper\">\n          <ul class=\"row\">\n            <li class=\"col-sm-4\"><strong>Providing Care Since: </strong></li>\n            <li class=\"col-sm-8\">1984</li>\n          </ul>\n          <ul class=\"row\">\n            <li class=\"col-sm-4\"><strong>Medical Education: </strong></li>\n            <li class=\"col-sm-8\">University of California, Irvine, CA - Graduated in 1982</li>\n          </ul>\n          <ul class=\"row\">\n            <li class=\"col-sm-4\"><strong>Residency: </strong></li>\n            <li class=\"col-sm-8\">General Surgery from the University of Iowa, Iowa City, IA</li>\n          </ul>\n          <ul class=\"row\">\n            <li class=\"col-sm-4\"><strong>Specialties: </strong></li>\n            <li class=\"col-sm-8\">General Surgery, Varicose Veins (Phlebology)</li>\n          </ul>\n          <ul class=\"row\">\n            <li class=\"col-sm-4\"><strong>Board Certification: </strong></li>\n            <li class=\"col-sm-8\">Board Certified in Surgery by the American Board of Medical Specialties</li>\n          </ul>\n          <ul class=\"row\">\n            <li class=\"col-sm-4\"><strong>Memberships: </strong></li>\n            <li class=\"col-sm-8\">American College of Surgeons, American Academy of Cosmetic Surgery</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n    \n    <!-- Photo Column -->\n    <div class=\"col-12 col-md-6\">\n      <div class=\"doctor-photo-container\" style=\"text-align: center;\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0522/8678/3654/files/dr-ronald-kolegraff-600x903.webp?v=1775459970%20alt=\" a rather dated photo of dr. kolegraff in scrubs fixing varicose vein without mustacheo style=\" max-width: height: auto border-radius: 