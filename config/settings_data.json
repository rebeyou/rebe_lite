            }
          },
          "cdd7544a-04a6-4c1f-b6b7-1255bbf1d86c": {
            "type": "html",
            "settings": {
              "code": "<div class=\"container\">\n    <div class=\"row m-b-n30\">\n        <div class=\"col-12\">\n            <div class=\"service-long-title text-center\">\n              <h2 class=\"title\">\n                <span class=\"text-main\">The Advantages of</span> Endovenous Laser Ablation<br>And How Quickly<span class=\"text-main\"> You Will Recover.</span>\n              </h2>\n            </div>\n        </div>\n        <div class=\"col-12 col-lg-6 col-el-4 m-b-30\">\n            <div class=\"single-service\">\n                <div class=\"single-service-title\">\n                  <h2 class=\"title\">Relief of symptoms</h2>\n                  <p>EVLA uses laser energy to treat a vein with extreme precisions.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"col-12 col-lg-6 col-el-4 m-b-30\">\n            <div class=\"single-service\">\n                <div class=\"single-service-title\">\n                  <h2 class=\"title\">Non-surgical procedure</h2>\n                  <p>Lasers procedures have proved to be safe and effective through years of medical procedures and their application.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"col-12 col-lg-6 col-el-4 m-b-30\">\n            <div class=\"single-service\">\n                <div class=\"single-service-title\">\n                  <h2 class=\"title\">Little downtime</h2>\n                  <p>You may resume most activities immediately following the procedure.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"col-12 col-lg-6 col-el-4 m-b-30\">\n            <div class=\"single-service\">\n                <div class=\"single-service-title\">\n                  <h2 class=\"title\">Same day, outpatient procedure</h2>\n                  <p>Wear compression stockings following treatment.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"col-12 col-lg-6 col-el-4 m-b-30\">\n            <div class=\"single-service\">\n                <div class=\"single-service-title\">\n                  <h2 class=\"title\">Little to no scarring</h2>\n                  <p>You might notice a bit of bruising post-treatment which should last no more than 6 weeks.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"col-12 col-lg-6 col-el-4 m-b-30\">\n            <div class=\"single-service\">\n                <div class=\"single-service-title\">\n                  <h2 class=\"title\">Local Anesthesia</h2>\n                  <p>EVLA is done in the clinic under local anesthesia and physical activity is encouraged after the procedure</p>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>",
              "width": "100%",
              "align": "auto"
            }
          }
        },
