      "advanced-content-page-4-5": {
        "type": "advanced-content-page-4-5",
        "blocks": {
          "411f5438-b43a-4b9f-ac51-c6c3e0cbf6cb": {
            "type": "image",
            "settings": {
              "width": "50%",
