          "0fdaacfe-902f-4e9b-92fc-5089ae9ec91b": {
            "type": "html",
            "settings": {
              "code": "<div class=\"row align-items-center layout-column-2\">\n    <div class=\"col-12 col-md-12\">\n        <div class=\"py-5\">\n            <div class=\"py-4 pl-2\">\n                <h3 class=\"h3 bottom-title\">The Best</h3>\n                <h3 class=\"text-main line-after\">CoolSculpting<br>\nLower Tummy</h3>\n                <p class=\"text-blue-main text-italic\">CoolSculpting® results before and after on the lower tummy.</p>\n<p>Re*be® is happy to offer coolsculpting® and excited to be able to participate in treatments that can offer results like these without downtime and without surgery. Everyone's results are different. </p>\n            </div>\n        </div>\n    </div>\n</div>",
