            "type": "html",
            "settings": {
              "code": "<div class=\"service-pricing bg-name-primary\">\n    <h3 class=\"service-pricing-title\">Different Skin Lesions</h3>\n    <table class=\"table table-borderless mb-0\">\n        <tbody>\n            <tr>\n                <td class=\"title-serv\">Pigmented Nevus</td>\n                <td class=\"middle-serv\">-</td>\n                <td class=\"price-serve\">Actinic Keratosis</td>\n            </tr>\n            <tr>\n                <td class=\"title-serv\">Basal Cell Carcinoma</td>\n                <td class=\"middle-serv\">-</td>\n                <td class=\"price-serve\">Carbuncle</td>\n            </tr>\n            <tr>\n                <td class=\"title-serv\">Sebaceous cyst</td>\n                <td class=\"middle-serv\">-</td>\n                <td class=\"price-serve\">Inclusion cyst</td>\n            </tr>\n            <tr>\n                <td class=\"title-serv\">Squamous Cell Carcinoma</td>\n                <td class=\"middle-serv\">-</td>\n                <td class=\"price-serve\">Furuncle</td>\n            </tr>\n        </tbody>\n    </table>\n</div>",
              "width": "100%",
              "align": "auto"
            }
          }
        },
