            "type": "html",
            "settings": {
              "code": "<div class=\"row align-items-center layout-column-2\">\n    <div class=\"col-12 col-md-12\">\n        <div class=\"py-5\">\n            <div class=\"py-4 pl-2\">\n                <h3 class=\"h3 bottom-title\">Meet Us!</h3>\n                <h3 class=\"text-main line-after\">The Staff<br>\nAt Re*be</h3>\n                <p class=\"text-blue-main text-italic\">One of our best assets for providing quality care.</p>\n<p>Please visit us at the Clinic in Okoboji or one of our many outreach locations.</p>\n<button type=\"submit\" class=\"btn btn-theme\" name=\"commit\"><a href=\"https://www.coolsculpting.com\">\n                        <span class=\"text-white\">Contact Us</span>\n                        <span class=\"\"><i class=\"icon-send\"></i></span>\n                      </a></button>\n            </div>\n        </div>\n    </div>\n</div>",
