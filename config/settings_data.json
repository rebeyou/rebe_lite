              "code": "<div class=\"row align-items-center layout-column-2 after-bg\">\n    <div class=\"col-12 col-md-12\">\n        <div class=\"py-5 mb-4\">\n            <div class=\"py-4 pl-2\">\n                <h2 class=\"h3 bottom-title\">Meet Us</h2>\n                <h1 class=\"text-white line-after\">Dr. Kolegraff<br><span class=\"small-text\">MD FACS RVT</span>\n</h1>\n                <p class=\"text-white\">Dr. Kolegraff is licensed to practice medicine in Iowa. He is one of only a few physicians who has shown the commitment to licensing and credentials to actually obtain his RVT. </p>\n<p class=\"text-white\">Dr. Kolegraff and everyone at re*be® ensure they have the credentials to provide quality patient care. Give us a call to learn more!</p>\n<button type=\"submit\" class=\"btn btn-theme mainlys\" name=\"commit\"><a class=\"mainlys-inner\" href=\"https://rebeyou.com/pages/about\">\n                        <span style=\"margin-right: 16px;\">Find out about us</span>\n                        <span class=\"\"><i class=\"icon-send\"></i></span>\n                      </a></button>\n            </div>\n        </div>\n    </div>\n</div>",
