          "31ba5331-512a-4f03-816e-c6be1fb1a4a6": {
            "type": "html",
            "settings": {
              "code": "<div class=\"row align-items-center layout-column-2\">\n    <div class=\"col-12 col-md-12\">\n        <div class=\"py-5\">\n            <div class=\"py-4 pl-2\">\n                <h3 class=\"h3 bottom-title\">Female Patient</h3>\n                <h3 class=\"text-main line-after\">Multiple Treatments</h3>\n                <p class=\"text-blue-main text-italic\">Notable improvement after 4 very superficial laser peels of 10 microns.</p>\n            </div>\n        </div>\n    </div>\n</div>",
